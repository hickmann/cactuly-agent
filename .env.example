# CodeShield SAST agent: .env
# Copie pra .env e preencha. Não commite este arquivo com valores reais.

# Onde o CodeShield SaaS mora (default = https://usecodeshield.com)
CODESHIELD_API_URL=https://usecodeshield.com

# Enrollment token: gere em /admin > Agents > "Novo agent". É one-shot;
# depois do primeiro up, o agent guarda um JWT em /data/agent-state.json
# e passa a renová-lo sozinho antes de expirar.
WORKER_ENROLLMENT_TOKEN=

# Poll interval de jobs em ms (default 5000)
CODESHIELD_POLL_MS=5000

# Intervalo de heartbeat em ms (default 30000)
CODESHIELD_HEARTBEAT_MS=30000

# Senha do Postgres embutido. Gere uma random e MANTENHA aqui;
# perder isso significa perder a fila local de jobs (tabela codeshield_jobs), mas não os dados no CodeShield.
POSTGRES_PASSWORD=

# Tag da imagem do agent-runtime (deixe latest a menos que queira pinning explícito)
AGENT_RUNTIME_TAG=latest

# API local de jobs (só faz sentido nos modos de fila local/custom, definidos
# pelo super admin no painel). Sem token, a API local fica desligada.
# Gere um token forte, ex.: openssl rand -hex 32
CODESHIELD_LOCAL_API_TOKEN=
CODESHIELD_LOCAL_API_PORT=8484

# Nomes legados ainda aceitos (com aviso de deprecação no log do agent):
#   CACTULY_API_URL / CACTULY_ENDPOINT  -> use CODESHIELD_API_URL
#   CACTULY_ENROLLMENT_TOKEN            -> use WORKER_ENROLLMENT_TOKEN
#   CACTULY_POLL_MS                     -> use CODESHIELD_POLL_MS
#   CACTULY_HEARTBEAT_MS                -> use CODESHIELD_HEARTBEAT_MS
#   CACTULY_LOCAL_API_TOKEN             -> use CODESHIELD_LOCAL_API_TOKEN
#   CACTULY_LOCAL_API_PORT              -> use CODESHIELD_LOCAL_API_PORT
