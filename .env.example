# Cactuly agent — .env
# Copie pra .env e preencha. Não commite este arquivo com valores reais.

# Onde o Cactuly SaaS mora (default = production URL do worker Cloudflare)
CACTULY_ENDPOINT=https://cactuly-portal.atlasberg.workers.dev

# Enrollment token — gere em /admin > Agents > "Novo agent". É one-shot;
# depois do primeiro up, o agent guarda um JWT permanente em /data/agent-state.json.
CACTULY_ENROLLMENT_TOKEN=

# Poll interval em ms (default 5000)
CACTULY_POLL_MS=5000

# Senha do Postgres embutido. Gere uma random e MANTENHA aqui;
# perder isso significa perder o pg-boss e agent_runs locais (mas não os dados no Cactuly).
POSTGRES_PASSWORD=

# Tag da imagem do agent-runtime (deixe latest a menos que queira pinning explícito)
AGENT_RUNTIME_TAG=latest
